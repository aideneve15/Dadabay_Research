metadata <- combinedWide |> select(1:4)

# Transform the rest
transformed <- combinedWide |> 
  select(-1, -2, -3, -4, -5) |>   # drop metadata columns
  baseline.corr()     # apply function

# Recombine
baselineWide <- bind_cols(metadata, transformed) 

species_df = split_by_species(combinedWide)
green <- species_df[['green']]
greenWide <-  correct_baseline(green, meta_in = TRUE)

greenLong_raw <- wide_to_long(green)
greenLong <- wide_to_long(greenWide)
plot_by_time(greenLong, title_input = "Baseline Corrected")
plot_by_time(greenLong_raw, title_input = "Raw Spectra")



